# Cell 1 - Imports
import sys
sys.path.append('../src')
from riskoptima import RiskOptima
import pandas as pd

# Cell 2 - Download Data (THIS IS WHERE YOU MAKE YOUR CHANGE)
assets = ['RELIANCE.NS', 'INFY.NS', 'HDFCBANK.NS', 'AAPL', 'MSFT', 'GOOGL']
start_date = '2020-01-01'
end_date = '2024-12-31'

prices = RiskOptima.download_data_yfinance(assets, start_date, end_date)
returns = prices.pct_change().dropna()
print(returns.head())

# Cell 3 - Compute Stats
expected_returns = RiskOptima.annualize_returns(returns, periods_per_year=252)
cov_matrix = returns.cov()
print("Expected Returns:\n", expected_returns)

# Cell 4 - Plot Efficient Frontier
import matplotlib.pyplot as plt
ax = RiskOptima.plot_ef(50, expected_returns, cov_matrix, show_cml=True,
                         show_ew=True, show_gmv=True, riskfree_rate=0.05)
plt.title("Efficient Frontier - Indian & US Equities")
plt.savefig('../results/efficient_frontier.png')
plt.show()

# Cell 5 - Sharpe Ratio
sharpe = RiskOptima.sharpe_ratio(returns, risk_free_rate=0.05)
print("Sharpe Ratios:\n", sharpe)
